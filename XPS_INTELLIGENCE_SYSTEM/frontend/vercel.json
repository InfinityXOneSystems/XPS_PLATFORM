{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",

  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true,
      "staging": true
    }
  },

  "env": {
    "VITE_API_URL": "https://xps-intelligence.up.railway.app",
    "VITE_GATEWAY_URL": "https://xps-intelligence.up.railway.app",
    "VITE_ENV": "production"
  },

  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://xps-intelligence.up.railway.app/api/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://xps-intelligence.up.railway.app/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://xps-intelligence.up.railway.app/health"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
