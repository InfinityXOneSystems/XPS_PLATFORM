# =============================================================================
# XPS Intelligence System — Frontend Environment Variables (Vercel / Vite)
# =============================================================================
# Copy this file to .env.local for local development.
# On Vercel, set these via the "Environment Variables" section in your project.
# All VITE_* variables are inlined at build time and visible in the browser.
# Do NOT put secrets in VITE_* variables.
# =============================================================================

# --- Backend API URL ---------------------------------------------------------
# Production: your Railway backend URL
# Local dev: http://localhost:8000
VITE_API_URL=https://xps-intelligence.up.railway.app

# --- Groq (client-side LLM chat, optional) ----------------------------------
# Only needed if the frontend calls Groq directly (not via backend proxy).
# If all LLM calls go through the backend, leave this blank.
VITE_GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Redis (optional, only if frontend uses Redis directly) -----------------
# Most frontends do NOT connect to Redis directly. Leave blank unless required.
VITE_REDIS_URL=

# --- Feature flags -----------------------------------------------------------
VITE_ENABLE_LLM_CHAT=true
VITE_ENABLE_SCRAPERS=true
VITE_ENABLE_AGENTS=true
