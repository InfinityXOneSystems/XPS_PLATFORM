# ============================================================
# XPS Intelligence – Dashboard Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.local.example .env.local
#
# Production values are set in the Vercel project settings.
# ============================================================

# ----------------------------------------------------------
# Backend / Gateway URL  (both point to the same Railway service)
#   Dev:   http://localhost:3099   (Express gateway: cd repo && PORT=3099 node api/gateway.js)
#   Prod:  https://xps-intelligence.up.railway.app
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3099

# ----------------------------------------------------------
# Express gateway URL (same service as API_URL for this project)
#   Dev:   http://localhost:3099
#   Prod:  https://xps-intelligence.up.railway.app
# ----------------------------------------------------------
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3099

# ----------------------------------------------------------
# Base path (set automatically by GitHub Pages / Vercel; leave blank for local)
# ----------------------------------------------------------
NEXT_PUBLIC_BASE_PATH=
