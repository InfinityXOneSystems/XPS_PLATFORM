# ── Railway PostgreSQL (primary lead storage) ────────────────────────────────
# Railway injects DATABASE_URL automatically when you link the Postgres addon:
#   Service vars → Add variable → Value: ${{ Postgres.DATABASE_URL }}
#
# Private network (preferred, faster — only accessible within Railway):
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres.railway.internal:5432/railway
# Public network (for local dev / external tools):
DATABASE_PUBLIC_URL=postgresql://postgres:CHANGE_ME@RAILWAY_TCP_PROXY_DOMAIN:PORT/railway

# Legacy individual vars — only used if DATABASE_URL is NOT set
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lead_intelligence
DATABASE_USER=lead_admin
DATABASE_PASSWORD=CHANGE_ME
# Set to "true" if the DB requires TLS/SSL (not needed on Railway private network)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ── Supabase (OPTIONAL — no longer primary storage) ──────────────────────────
# Supabase is no longer used for lead storage. Railway PostgreSQL is the source
# of truth.  Leave these blank unless you are running a Supabase integration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Workspace / outreach settings
GOOGLE_WORKSPACE_EMAIL=
OUTREACH_PHONE=

# ── AI Agent Backend ────────────────────────────────────────────────────────
# URL of the Python FastAPI agent server
AGENT_PORT=8000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# ── API Gateway ────────────────────────────────────────────────────────────
# Express API gateway port (default 3000, matches frontend expectation)
PORT=3000

# CORS: comma-separated list of allowed frontend origins (leave blank = allow all for local dev)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── LLM Configuration ──────────────────────────────────────────────────────
# Smart router mode: auto | groq | ollama | openai
LLM_PROVIDER=auto

# Groq cloud LLM (fastest; recommended for cloud deployments)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Ollama local LLM (free; requires running Ollama daemon)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP settings for outreach emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=XPS Intelligence

# GitHub token for workflow triggering
GITHUB_TOKEN=
GITHUB_REPOSITORY=InfinityXOneSystems/XPS_INTELLIGENCE_SYSTEM

# ── Infinity Orchestrator GitHub App ─────────────────────────────────────────
# The GitHub App "Infinity Orchestrator" has full admin read+write access to
# all InfinityXOneSystems repos. Its credentials unlock cross-repo writes
# (LEADS repo, XPS-INTELLIGENCE-FRONTEND repo) without a personal access token.
#
# How to configure:
#   1. Go to GitHub → Settings → Developer settings → GitHub Apps
#   2. Create app (or use existing "Infinity Orchestrator" app)
#      Permissions: Contents=Read+Write, Actions=Write, Metadata=Read
#      Install on InfinityXOneSystems org
#   3. Generate / download a private key (.pem)
#   4. Set these two GitHub Actions secrets on every repo that needs cross-repo access:
#      GH_APP_ID          — the numeric App ID from the App's settings page
#      GH_APP_PRIVATE_KEY — full PEM contents of the downloaded private key
#
# In .env (local dev): paste the PEM inline, replacing newlines with \n
GH_APP_ID=
GH_APP_PRIVATE_KEY=
# Optional: pin to a specific installation (auto-discovered if blank)
GH_APP_INSTALLATION_ID=

# ── Webhook Secrets ──────────────────────────────────────────────────────────
# These protect the inbound webhook endpoints at /webhooks/*
# Generate with: openssl rand -hex 32

# GitHub webhook HMAC-SHA256 shared secret
# Set this SAME value in: GitHub → Repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=

# Supabase webhook bearer token
# Set this SAME value as the Authorization: Bearer header in Supabase → Webhooks
SUPABASE_WEBHOOK_SECRET=

# Vercel deploy webhook signing secret (from Vercel → Team Settings → Webhooks)
VERCEL_WEBHOOK_SECRET=

# URL of the Infinity Orchestrator service (optional; omit if running single process)
ORCHESTRATOR_URL=http://localhost:3300

# Vercel frontend URL (added to CORS allowlist automatically)
FRONTEND_URL=
VERCEL_URL=

# Redis (BullMQ task queue)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production
