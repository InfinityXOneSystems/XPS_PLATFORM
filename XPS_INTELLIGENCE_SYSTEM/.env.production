# ─────────────────────────────────────────────────────────────────────────────
# .env.production — XPS Intelligence Backend Production Environment
#
# Usage:
#   Set these variables in Railway → Project → Variables (Backend service).
#   Railway auto-provides DATABASE_URL and REDIS_URL when the Postgres and
#   Redis plugins are added to the project.
#
# DO NOT commit real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway; only override for debugging.
PORT=8000
ENVIRONMENT=production
LOG_LEVEL=info
UVICORN_WORKERS=2

# ── Database (Railway Postgres plugin) ───────────────────────────────────────
# Railway auto-provides DATABASE_URL when the Postgres plugin is added.
# In the Railway dashboard → Variables, use the reference: ${{Postgres.DATABASE_URL}}
# Railway will resolve this to the actual connection string at runtime.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Redis (Railway Redis plugin) ─────────────────────────────────────────────
# Railway auto-provides REDIS_URL when the Redis plugin is added.
# In the Railway dashboard → Variables, use the reference: ${{Redis.REDIS_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# WARNING: The app will refuse to start if this is not replaced in production.
SECRET_KEY=REPLACE_ME_generate_with_openssl_rand_hex_32

# ── LLM Providers ────────────────────────────────────────────────────────────
# "auto" tries Groq → Ollama → OpenAI in priority order.
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── CORS / Frontend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://xps-intelligence.vercel.app,https://xps-intelligence-*.vercel.app,https://*.up.railway.app,http://localhost:3000,http://localhost:5173
FRONTEND_URL=https://xps-intelligence.vercel.app

# ── GitHub Integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Agent / Worker ────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=3
WORKER_POLL_TIMEOUT=5
SCRAPER_CONCURRENCY=10
MAX_LEADS_PER_DAY=100000
