# .env.local.example
# ====================
# Docker Desktop local environment variables for XPS Intelligence Platform
#
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# Then start the full stack with Docker Desktop:
#   docker compose -f docker-compose.yml -f docker-compose.desktop.yml up -d
#
# NOTE: .env.local is gitignored — never commit real secrets.

# ── Local paths (Docker volume mounts) ──────────────────────────────────────
# Adjust these to match your local folder layout.
# Windows example:
#   XPS_BACKEND_PATH=C:\XPS_PLATFORM\XPS_INTELLIGENCE_SYSTEM
#   XPS_FRONTEND_PATH=C:\XPS_PLATFORM\XPS-INTELLIGENCE-FRONTEND
#   XPS_LEADS_PATH=C:\XPS_PLATFORM\LEADS
XPS_BACKEND_PATH=.
XPS_FRONTEND_PATH=../XPS-INTELLIGENCE-FRONTEND
XPS_LEADS_PATH=../LEADS

# ── PostgreSQL (local Docker — mirrors Railway Postgres plugin) ──────────────
POSTGRES_USER=xps
POSTGRES_PASSWORD=xpspass
POSTGRES_DB=xps
DATABASE_URL=postgresql://xps:xpspass@postgres:5432/xps

# ── Redis (local Docker — mirrors Railway Redis plugin) ─────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama (local Docker — mirrors Railway Ollama service) ───────────────────
# Model is pulled automatically on first startup. Recommended: llama3.2
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── LLM Provider ────────────────────────────────────────────────────────────
# "auto"   → Groq first (if key set), then Ollama
# "groq"   → Force Groq (requires GROQ_API_KEY)
# "ollama" → Force local Ollama container
LLM_PROVIDER=auto

# ── Groq (used by XPS-INTELLIGENCE-FRONTEND; also available to backend) ──────
# Get your key from https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── OpenAI (optional fallback) ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Supabase (primary lead storage) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # Get from Supabase → Settings → API
SUPABASE_SERVICE_ROLE_KEY=        # Get from Supabase → Settings → API (keep secret!)

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                     # PAT with repo write access

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=local-dev-key-change-me

# ── Backend / Gateway ports ──────────────────────────────────────────────────
PORT=3000
AGENT_PORT=8000

# ── Frontend (XPS-INTELLIGENCE-FRONTEND) ────────────────────────────────────
# VITE_API_URL points the Vite dev server at the local backend gateway.
VITE_API_URL=http://localhost:3000
# CORS: allow the local Vite dev server and any Railway/Vercel preview URLs.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://xps-intelligence.vercel.app
FRONTEND_URL=http://localhost:5173

