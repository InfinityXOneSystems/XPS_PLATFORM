# =============================================================================
# XPS Intelligence System — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# On Railway, set these via the "Variables" tab in your service dashboard.
# Railway auto-injects DATABASE_URL and REDIS_URL when you link the services.
# =============================================================================

# --- Database (Railway Postgres) -------------------------------------------
# Railway automatically sets this when you link a Postgres plugin/service.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# --- Cache (Railway Redis) --------------------------------------------------
# Railway automatically sets this when you link a Redis plugin/service.
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# --- Vector Store (Qdrant) --------------------------------------------------
# If using Railway-hosted Qdrant; otherwise point to your Qdrant Cloud URL.
QDRANT_URL=http://qdrant.railway.internal:6333

# --- LLM (Ollama) -----------------------------------------------------------
# If using Railway-hosted Ollama service.
OLLAMA_BASE_URL=http://ollama.railway.internal:11434

# --- LLM (Groq) -------------------------------------------------------------
# Get your API key from https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- LLM (OpenAI - optional fallback) --------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Security ---------------------------------------------------------------
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret

# Admin API secret — protects /admin/hidden/* endpoints.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change-me-to-a-strong-random-admin-secret

# --- External Services ------------------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=InfinityXOneSystems/XPS_INTELLIGENCE_SYSTEM
GOOGLE_SHEETS_CREDENTIALS={}

# --- Worker Configuration ---------------------------------------------------
WORKER_COUNT=2
ENABLE_WORKERS=true

# --- Scraper Configuration --------------------------------------------------
SCRAPER_CONCURRENCY=10
MAX_LEADS_PER_DAY=100000
